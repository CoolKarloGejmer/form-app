    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.12.3",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
